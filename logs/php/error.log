гӮ№гғҲгғһгғғгӮ№гғ«гғ—гғӯгғҶгӮӨгғі'; public $post_excerpt = 'гӮӘгғ—гғҶгӮЈгғһгғ гғӢгғҘгғјгғҲгғӘгӮ·гғ§гғіпјҲOptimum NutritionпјүгҒҢиЈҪйҖ иІ©еЈІгҒҷгӮӢгҖҢгӮҙгғјгғ«гғүгӮ№гӮҝгғігғҖгғјгғү100пј…гғӣгӮЁгӮӨгҖҚгҒҜгҖҒдё–з•ҢдёӯгҒ§ж„ӣйЈІгҒ•гӮҢгҒҰгҒ„гӮӢе®ҡз•Әгғ—гғӯгғҶгӮӨгғігҒ§гҒҷгҖӮ\r\nгӮӘгғ—гғҶгӮЈгғһгғ гғӢгғҘгғјгғҲгғӘгӮ·гғ§гғігҒЁгҒҜгҖҒпј‘пјҷпјҳпј–е№ҙгҒ«гӮўгғЎгғӘгӮ«гҒ§еүөжҘӯгҒ—гҒҹгӮ№гғқгғјгғ„ж „йӨҠиЈҪе“Ғгғ–гғ©гғігғүгҒ§гҒҷгҖӮ\r\nдё–з•Ңпјҷпјҗгғ¶еӣҪд»ҘдёҠгҒ§иІ©еЈІгҒ•гӮҢгҖҒгғ—гғӯгғҶгӮӨгғігҒ гҒ‘гҒ§гҒҜгҒӘгҒҸгҖҒгҒӮгӮүгӮҶгӮӢгӮөгғ—гғӘгғЎгғігғҲгӮ’иЈҪйҖ иІ©еЈІгҒ—гҒҰгҒ„гҒҫгҒҷгҖӮ'; public $post_status = 'publish'; public $comment_status = 'closed'; public $ping_status = 'open'; public $post_password = ''; public $post_name = '%e3%83%86%e3%82%b9%e3%83%88%e3%83%97%e3%83%ad%e3%83%86%e3%82%a4%e3%83%b3'; public $to_ping = ''; public $pinged = ''; public $post_modified = '2023-12-14 08:48:17'; public $post_modified_gmt = '2023-12-13 23:48:17'; public $post_content_filtered = ''; public $post_parent = 0; public $guid = 'http://bulkup.local/?post_type=protein_info&#038;p=440'; public $menu_order = 0; public $post_type = 'protein_info'; public $post_mime_type = ''; public $comment_count = '0'; public $filter = 'raw' }, 8 => class WP_Post { public $ID = 436; public $post_author = '1'; public $post_date = '2023-10-04 15:26:48'; public $post_date_gmt = '2023-10-04 06:26:48'; public $post_content = 'гғһгӮӨгғ—гғӯгғҶгӮӨгғігҖҖWHIгғ—гғӯгғҶгӮӨгғі\r\n\r\nгӮҝгғігғ‘гӮҜиіӘпј’пј‘G'; public $post_title = 'гғһгӮӨгғ—гғӯгғҶгӮӨгғігҖҖWHIгғ—гғӯгғҶгӮӨгғі'; public $post_excerpt = ''; public $post_status = 'publish'; public $comment_status = 'closed'; public $ping_status = 'open'; public $post_password = ''; public $post_name = '%e3%83%9e%e3%82%a4%e3%83%97%e3%83%ad%e3%83%86%e3%82%a4%e3%83%b3%e3%80%80whi%e3%83%97%e3%83%ad%e3%83%86%e3%82%a4%e3%83%b3'; public $to_ping = ''; public $pinged = ''; public $post_modified = '2023-12-06 19:24:56'; public $post_modified_gmt = '2023-12-06 10:24:56'; public $post_content_filtered = ''; publ